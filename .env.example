# Copy this file to .env and fill in real values. Never commit .env.

# LDAP / Active Directory Configuration
# REQUIRED
LDAP_SERVER_URL=ldaps://<AD_HOST>:636
LDAP_BASEDN=dc=example,dc=com
LDAP_BIND_USERNAME=cn=svc-dtrack,ou=ServiceAccounts,dc=example,dc=com

# OPTIONAL — defaults work for standard Active Directory
# LDAP_AUTH_USERNAME_FORMAT={0}@example.com   # UPN format; or cn={0},ou=Users,dc=example,dc=com for DN format
# LDAP_ATTRIBUTE_NAME=cn                       # attribute used as display name
# LDAP_ATTRIBUTE_MAIL=mail                     # attribute used as email
# LDAP_GROUPS_BASEDN=ou=Groups,dc=example,dc=com
# LDAP_GROUPS_FILTER=(&(objectClass=group)(member={USER_DN}))
# LDAP_USER_GROUPS_FILTER=(&(objectClass=group)(member={USER_DN}))

# --- Postgres password ---
# Stored in ./postgres_password secret file (chmod 600), not here.
# To change: ALTER USER in psql first, then update the file, then recreate containers.
# docker exec -it dtrack-postgres psql -U dtrack -d dtrack -c "ALTER USER dtrack WITH PASSWORD 'new-password';"
# echo -n 'new-password' > postgres_password
# docker compose up -d --force-recreate postgres dependency-track-apiserver

